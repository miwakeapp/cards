{
  "workspace": [
    "./data",
    "./jmdict_to_html",
    "./html_dictionary_previewer",
    "./card_creator",
    "./card_creator_evals"
  ],
  "imports": {
    "@quentinadam/zip": "jsr:@quentinadam/zip@^0.1.3",
    "@scriptin/jmdict-simplified-types": "npm:@scriptin/jmdict-simplified-types@^3.6.1",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/html": "jsr:@std/html@^1.0.5",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "iso-639-2": "npm:iso-639-2"
  },
  "tasks": {
    "prepare-leech-batch": "deno run --env-file=.env --allow-net --allow-read --allow-env anki_updater_prototype/prepare_leech_batch.ts",
    "create-leech-batch": "deno run --env-file=.env --allow-net --allow-read --allow-env anki_updater_prototype/create_leech_batch.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "proseWrap": "never",
    "exclude": [
      "anki_updater_prototype/*.html"
    ]
  }
}
