{
  "imports": {
    "@quentinadam/zip": "jsr:@quentinadam/zip@^0.1.3",
    "@scriptin/jmdict-simplified-types": "npm:@scriptin/jmdict-simplified-types@^3.6.1",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/testing": "jsr:@std/testing@^1.0.16"
  },
  "test": {
    "permissions": {
      "read": ["./test/inputs", "./test/__snapshots__"]
    }
  },
  "tasks": {
    "download_jmdict": "deno run --allow-net --allow-write=./src/jmdict_eng.json scripts/download_jmdict.mts",
    "extract_tests": "deno run --allow-read=./src/jmdict_eng.json --allow-write=./test/inputs scripts/extract_tests.mts",
    "test:update": "deno test --allow-read --allow-write -- --update"
  },
  "fmt": {
    "lineWidth": 100,
    "proseWrap": "never"
  }
}
