{
  "tasks": {
    "doc:check": "deno doc --lint server.ts scripts/build_entries.ts src/main.ts",
    "prepare_data": "deno run --allow-read=../data/preextracted_jmdict_entries,../data/jmdict_tags.json --allow-write=./src/data scripts/build_entries.ts",
    "build": "deno task prepare_data && deno transpile --output=./src/main.js ./src/main.ts",
    "dev": "deno task build && deno run --allow-net=127.0.0.1 --allow-read=./src server.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ]
  }
}
