{
  "tasks": {
    "doc:check": "deno doc --lint src/main.ts src/client/main.ts scripts/build_entries.ts",
    "prepare:data": "deno run --allow-read=../data/resources/jmdict --allow-write=./build scripts/build_entries.ts",
    "build": "deno task prepare:data && deno transpile --output=./build/main.js ./src/client/main.ts",
    "dev": "deno task build && deno run --allow-net=127.0.0.1 --allow-read=./src/client,./build src/main.ts"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ]
  }
}
